{
  "name": "ledgertwelve",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "pi": "agentignore run pi",
    "pi:backend": "agentignore run --source /workspaces/ledgertwelve/backend pi",
    "dev:backend": "dotnet run --project backend/ledger12.API",
    "build:backend": "dotnet build backend/ledger12.API",
    "build:frontend": "npm run build --prefix frontend",
    "test:backend": "dotnet test backend/ledger12.slnx",
    "test:frontend": "npm run test --prefix frontend",
    "dev": "concurrently -n API,UI -c \"cyan,magenta\" \"dotnet run --project backend/ledger12.API\" \"npm run dev:proxy --prefix frontend\"",
    "test": "npm run test:backend && npm run test:frontend",
    "build": "npm run build:backend && npm run build:frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@xlansoftware/agentignore": "^0.4.3",
    "concurrently": "^9.2.1"
  }
}
